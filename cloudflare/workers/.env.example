# Cloudflare Workers Environment Variables
# Copy this file to .env and fill in your values
# Note: Secrets should be set with: wrangler secret put API_KEY --env production

# Cloudflare Account ID (get from Cloudflare Dashboard > Account Settings)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# API Key for authorization (Bearer token)
# Set this securely with: wrangler secret put API_KEY
API_KEY=your_secure_api_key_here

# ElevenLabs API Key (for Aura-2 TTS, if using external API)
# Set this securely with: wrangler secret put ELEVENLABS_API_KEY
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Environment (development, staging, production)
ENVIRONMENT=production

# Cloudflare Zone ID (for routes configuration)
ZONE_ID=your_zone_id_here

# Domain name
DOMAIN=api.example.com
